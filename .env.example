# Chave da API do Google Gemini
GEMINI_API_KEY=sua-chave-aqui

# Endpoint CDP do Chrome (abra o Chrome com: google-chrome --remote-debugging-port=9222)
CDP_ENDPOINT=http://localhost:9222

# Modelo do Gemini (gemini-2.5-pro ou gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-pro

# Limite de candidaturas por execucao
LIMITE_DIARIO=10

# Delay entre acoes (ms)
DELAY_MIN=2000
DELAY_MAX=5000

# Modo Dry-Run (true = faz tudo menos submeter a candidatura de verdade)
DRY_RUN=true

# Score minimo para aplicar (1-10, quanto maior mais restritivo)
SCORE_MINIMO=6

# Dashboard (porta do servidor web local)
DASHBOARD_PORT=3000

# ============================================================
# TELEGRAM (opcional — preencha para receber notificações)
# 1. Fale com @BotFather no Telegram e crie um bot
# 2. Copie o token do bot
# 3. Envie uma mensagem para o bot e acesse:
#    https://api.telegram.org/bot<SEU_TOKEN>/getUpdates
#    para obter seu chat_id
# ============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# EMAIL (opcional — preencha para receber relatório por email)
# Para Gmail: use uma "Senha de App" em vez da senha normal
# Gere em: https://myaccount.google.com/apppasswords
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_DESTINATARIO=

# ============================================================
# CRON (agendamento automático — desativado por padrão)
# Ative para o bot executar automaticamente no horário definido
# ============================================================
CRON_ATIVO=false
CRON_HORARIO=09:00

# ============================================================
# MULTI-LLM (opcional — provider para cover letter, currículo,
# mensagem recrutador. O agente principal sempre usa Gemini.)
# Providers: gemini (padrão), ollama (local/grátis), openai
# ============================================================
LLM_AUX_PROVIDER=gemini
LLM_AUX_MODEL=gemini-2.5-pro

# Ollama (se LLM_AUX_PROVIDER=ollama)
# Instale: https://ollama.com — depois: ollama pull llama3
OLLAMA_URL=http://localhost:11434
# LLM_AUX_MODEL=llama3

# OpenAI-compatible (se LLM_AUX_PROVIDER=openai)
# Funciona com: OpenAI, Together AI, Groq, Mistral, vLLM
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_AUX_MODEL=gpt-4o-mini
